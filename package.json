{
  "name": "renda",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n app,api -c cyan,magenta \"npm run dev -w @renda/app\" \"npm run dev -w @renda/api\"",
    "dev:app": "npm run dev -w @renda/app",
    "dev:api": "npm run dev -w @renda/api",
    "build": "npm run build -w @renda/app",
    "preview": "npm run preview -w @renda/app",
    "remotion:studio": "npm run remotion:studio -w @renda/composition",
    "remotion:render": "npm run remotion:render -w @renda/composition"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.5.4"
  }
}
